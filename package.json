{
  "name": "local-ai-scanner-cli",
  "version": "0.1.0",
  "description": "Cached hardware price scanner CLI for local.ai — pulls current market prices for GPUs, Apple Silicon, AMD, and memory across US and global retailers.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "bin": "./src/bin.ts",
  "files": [
    "src/",
    "lib/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/0xSero/local-ai-scanner-cli.git"
  },
  "bugs": {
    "url": "https://github.com/0xSero/local-ai-scanner-cli/issues"
  },
  "scripts": {
    "scan": "tsx src/cli.ts scan",
    "prices": "tsx src/cli.ts prices",
    "export": "tsx src/export-data.ts",
    "scan:gpu": "tsx src/cli.ts scan --category gpu",
    "scan:apple": "tsx src/cli.ts scan --category apple",
    "scan:memory": "tsx src/cli.ts scan --category memory",
    "scan:amd": "tsx src/cli.ts scan --category amd",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "./package.json": "./package.json"
    },
    "bin": "./dist/src/bin.js",
    "access": "public"
  },
  "dependencies": {
    "cheerio": "^1.0.7",
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
