{
  "name": "local-ai-scanner-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Cached hardware price scanner CLI for local.ai — pulls current market prices for GPUs, Apple Silicon, AMD, and memory across US and global retailers.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "scan": "tsx src/cli.ts scan",
    "prices": "tsx src/cli.ts prices",
    "export": "tsx src/export-data.ts",
    "scan:gpu": "tsx src/cli.ts scan --category gpu",
    "scan:apple": "tsx src/cli.ts scan --category apple",
    "scan:memory": "tsx src/cli.ts scan --category memory",
    "scan:amd": "tsx src/cli.ts scan --category amd",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.7",
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
